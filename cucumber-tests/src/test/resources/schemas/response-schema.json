{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessResponse",
  "type": "object",
  "required": ["result", "id"],
  "properties": {
    "result": {
      "type": "string",
      "enum": ["success", "failure"]
    },
    "id": {
      "type": "string",
      "description": "Unique transaction identifier"
    },
    "message": {
      "type": "string",
      "description": "Optional response message"
    }
  },
  "additionalProperties": false
}
